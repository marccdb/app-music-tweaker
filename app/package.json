{
  "name": "ModAudio",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "dev:desktop": "vite --config vite.desktop.config.ts",
    "build:desktop": "tsc -p tsconfig.electron.json --noEmit && vite build --config vite.desktop.config.ts",
    "dist:desktop": "npm run build:desktop && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium firefox webkit",
    "licenses:check": "node scripts/licenses.mjs check",
    "licenses:notices": "node scripts/licenses.mjs notices",
    "qa:package-smoke": "node scripts/package-smoke.mjs",
    "qa:memory-long-file": "node --expose-gc scripts/memory-long-file-check.mjs",
    "qa:desktop": "npm run qa:memory-long-file && npm run qa:package-smoke"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "soundtouchjs": "^0.3.0",
    "vue": "^3.5.35",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "electron": "42.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^1.0.0-beta.13",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  },
  "build": {
    "appId": "com.modaudio.app",
    "asar": true,
    "afterPack": "scripts/afterPack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ]
  }
}
